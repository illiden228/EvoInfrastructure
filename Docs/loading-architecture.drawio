  <diagram id="loading-architecture" name="Loading Architecture">
    <mxGraphModel dx="1600" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title" value="Evo Loading Architecture" style="text;html=1;strokeColor=none;fillColor=none;fontSize=28;fontStyle=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="40" y="30" width="520" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="note" value="Core idea: game code sends a typed LoadingRequest. LoadingService resolves scene metadata, builds a pipeline through step providers, then runs ordered weighted steps." style="text;html=1;strokeColor=none;fillColor=none;fontSize=14;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="40" y="75" width="900" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="apiGroup" value="Public API" style="swimlane;html=1;rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=16;fontStyle=1;startSize=30;" vertex="1" parent="1">
          <mxGeometry x="40" y="150" width="390" height="330" as="geometry"/>
        </mxCell>
        <mxCell id="loadingService" value="&lt;b&gt;ILoadingService&lt;/b&gt;&lt;br/&gt;+ LoadStartupAsync()&lt;br/&gt;+ LoadSceneAsync(sceneId)&lt;br/&gt;+ LoadAsync(request)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;align=left;spacing=10;" vertex="1" parent="apiGroup">
          <mxGeometry x="30" y="50" width="330" height="95" as="geometry"/>
        </mxCell>
