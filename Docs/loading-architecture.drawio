          <mxGeometry x="30" y="165" width="330" height="125" as="geometry"/>
        </mxCell>

        <mxCell id="catalogGroup" value="Configuration" style="swimlane;html=1;rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=16;fontStyle=1;startSize=30;" vertex="1" parent="1">
          <mxGeometry x="470" y="150" width="410" height="330" as="geometry"/>
        </mxCell>
        <mxCell id="sceneCatalog" value="&lt;b&gt;SceneCatalog&lt;/b&gt;&lt;br/&gt;+ Find(SceneId)&lt;br/&gt;+ StartupSceneId&lt;br/&gt;+ Definitions[]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;align=left;spacing=10;" vertex="1" parent="catalogGroup">
