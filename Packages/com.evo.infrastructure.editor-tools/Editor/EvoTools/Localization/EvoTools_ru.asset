    m_Localized: "\u0418\u043C\u043F\u043E\u0440\u0442 ResourceCatalog \u0437\u0430\u0432\u0435\u0440\u0448\u0451\u043D.
      \u0414\u043E\u0431\u0430\u0432\u043B\u0435\u043D\u043E: {0}, \u041E\u0431\u043D\u043E\u0432\u043B\u0435\u043D\u043E:
      {1}, \u041F\u0440\u043E\u043F\u0443\u0449\u0435\u043D\u043E: {2}. \u041F\u0430\u043F\u043A\u0430:
