      m_Items: []
  - m_Id: 383858032762880
    m_Localized: "\u041F\u043E\u043A\u0430\u0437\u0430\u0442\u044C \u043A\u0430\u0442\u0430\u043B\u043E\u0433"
    m_Metadata:
      m_Items: []
  - m_Id: 812970501201920
    m_Localized: "\u0415\u0434\u0438\u043D\u0438\u0446\u044B \u0432 \u0441\u0435\u043A\u0443\u043D\u0434\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 813540649721856
    m_Localized: "\u0413\u0440\u0430\u0434\u0443\u0441\u043E\u0432 \u0432 \u0441\u0435\u043A\u0443\u043D\u0434\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 813573893775360
    m_Localized: "\u041E\u0442\u0440\u0438\u0446\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0435
      \u0443\u0441\u043A\u043E\u0440\u0435\u043D\u0438\u0435 \u0432\u043D\u0438\u0437."
    m_Metadata:
      m_Items: []
  - m_Id: 813615144755200
    m_Localized: "\u041C\u0430\u043A\u0441\u0438\u043C\u0430\u043B\u044C\u043D\u0430\u044F
      \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u044C \u043F\u0430\u0434\u0435\u043D\u0438\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 813674242498560
    m_Localized: "\u0421\u043A\u043E\u0440\u043E\u0441\u0442\u044C \u043F\u0440\u0438\u0436\u0438\u043C\u0430\u043D\u0438\u044F
      \u043A \u0437\u0435\u043C\u043B\u0435."
    m_Metadata:
      m_Items: []
  - m_Id: 813771302887424
    m_Localized: "\u0421\u043C\u0435\u0440\u0442\u044C \u043F\u0440\u0438 \u043F\u0430\u0434\u0435\u043D\u0438\u0438
      \u043D\u0438\u0436\u0435 \u044D\u0442\u043E\u0439 \u0432\u044B\u0441\u043E\u0442\u044B."
    m_Metadata:
      m_Items: []
  - m_Id: 813814600687616
    m_Localized: "\u041A\u0430\u043A \u0447\u0430\u0441\u0442\u043E \u0431\u043E\u0442
      \u0432\u044B\u0431\u0438\u0440\u0430\u0435\u0442 \u043D\u043E\u0432\u043E\u0435
      \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435 \u0431\u043B\u0443\u0436\u0434\u0430\u043D\u0438\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 813886868545536
    m_Localized: "\u0421\u0438\u043B\u0430 \u043F\u043E\u0432\u043E\u0440\u043E\u0442\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 813937145667584
    m_Localized: "\u0421\u0433\u043B\u0430\u0436\u0438\u0432\u0430\u043D\u0438\u0435
      \u043F\u0440\u0438 \u043D\u0430\u0432\u0435\u0434\u0435\u043D\u0438\u0438 \u043D\u0430
      \u0446\u0435\u043B\u044C."
    m_Metadata:
      m_Items: []
  - m_Id: 813992208490496
    m_Localized: "\u0421\u0438\u043B\u0430 \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u043E\u0433\u043E
      \u0431\u043B\u0443\u0436\u0434\u0430\u043D\u0438\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 814059535458304
    m_Localized: "\u0414\u0438\u0441\u0442\u0430\u043D\u0446\u0438\u044F \u043F\u0440\u043E\u0432\u0435\u0440\u043A\u0438
      \u0432\u043F\u0435\u0440\u0435\u0434."
    m_Metadata:
      m_Items: []
  - m_Id: 814095560335360
    m_Localized: "\u0414\u043B\u0438\u043D\u0430 \u0440\u0435\u0439\u043A\u0430\u0441\u0442\u0430
      \u0434\u043B\u044F \u043F\u0440\u043E\u0432\u0435\u0440\u043A\u0438 \u043E\u0442\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u044F
      \u0437\u0435\u043C\u043B\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 814095560335361
    m_Localized: "\u0414\u043E\u0431\u0430\u0432\u044C\u0442\u0435 \u0442\u0435\u043A\u0441\u0442 \u043F\u043E\u0434\u0441\u043A\u0430\u0437\u043E\u043A \u0434\u043B\u044F \u043A\u043B\u044E\u0447\u0435\u0439 \u0432 \u0442\u0430\u0431\u043B\u0438\u0446\u0443 \u043B\u043E\u043A\u0430\u043B\u0438\u0437\u0430\u0446\u0438\u0438 EvoTools. \u0418\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0439\u0442\u0435 Tooltip Key."
    m_Metadata:
      m_Items: []
  - m_Id: 814095560335362
    m_Localized: "\u041A\u043B\u044E\u0447 \u043B\u043E\u043A\u0430\u043B\u0438\u0437\u0430\u0446\u0438\u0438 \u0432 \u0442\u0430\u0431\u043B\u0438\u0446\u0435 EvoTools \u0434\u043B\u044F \u043F\u043E\u0434\u0441\u043A\u0430\u0437\u043A\u0438. \u041E\u0441\u0442\u0430\u0432\u044C\u0442\u0435 \u043F\u0443\u0441\u0442\u044B\u043C, \u0447\u0442\u043E\u0431\u044B \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C Comment."
    m_Metadata:
      m_Items: []
  - m_Id: 814095560335363
    m_Localized: "\u0417\u0430\u0434\u0430\u0439\u0442\u0435 adapter id \u0438 \u043F\u043E\u0434\u0441\u043A\u0430\u0437\u043A\u0438. \u0418\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0439\u0442\u0435 \u044D\u0442\u043E\u0442 \u043A\u0430\u0442\u0430\u043B\u043E\u0433 \u0434\u043B\u044F \u0432\u044B\u043F\u0430\u0434\u0430\u044E\u0449\u0438\u0445 \u0441\u043F\u0438\u0441\u043A\u043E\u0432."
    m_Metadata:
      m_Items: []
  - m_Id: 814095560335364
    m_Localized: "\u041A\u043B\u044E\u0447 \u043B\u043E\u043A\u0430\u043B\u0438\u0437\u0430\u0446\u0438\u0438 \u0432 \u0442\u0430\u0431\u043B\u0438\u0446\u0435 EvoTools \u0434\u043B\u044F \u043F\u043E\u0434\u0441\u043A\u0430\u0437\u043A\u0438. \u041E\u0441\u0442\u0430\u0432\u044C\u0442\u0435 \u043F\u0443\u0441\u0442\u044B\u043C, \u0447\u0442\u043E\u0431\u044B \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C Comment."
